local function GetAlpha(current, max)
	if not current or not max or max == 0 then return 1 end
	return math.clamp(current / max, 0, 1)
end

local function KeyCode(key)
	return typeof(key) == "EnumItem" and key or Enum.KeyCode[key]
end

local ConnectionService = {}

ConnectionService.TargetConnections = {}
ConnectionService.PlayerConnections = {}

ConnectionService.Delays            		 = {}

ConnectionService.LiveConnections 	 = {}

function ConnectionService:NewConnection(name, signal, connType, scope, callback,extra)
	if Warning(" ", name) == "STOP"
		or Warning(" ", signal) == "STOP"
		or Warning(" ", connType) == "STOP"
		or Warning(" ", scope) == "STOP" then
		return
	end

	local container = scope == "Player"
		and ConnectionService.PlayerConnections
		or scope == "Target" and ConnectionService.TargetConnections
		or ConnectionService.LiveConnections[extra]

	if container[name] then
		container[name]:Disconnect()
		container[name] = nil
	end

	callback = callback or function() end

	local conn
	if connType == "Connect" then
		conn = signal:Connect(callback)
	elseif connType == "Once" then
		conn = signal:Once(function(...)
			callback(...)
			container[name] = nil
		end)
	elseif connType == "Wait" then
		signal:Wait()
	end

	container[name] = conn
	return conn
end

function ConnectionService.Disconnect(scope, name,extra)
	if Warning(" ", scope) == "STOP" then return end

	local container = scope == "Player"
		and ConnectionService.PlayerConnections
		or scope == "Target" and ConnectionService.TargetConnections
		or ConnectionService.LiveConnections[extra]

	if name then
		if container[name] then
			container[name]:Disconnect()
			container[name] = nil
		end
	else
		for k, v in pairs(container) do
			v:Disconnect()
			container[k] = nil
		end
	end
end

function ConnectionService:Delay(name, waitTime, callback)
	if Warning(" ", name) == "STOP"
		or Warning(" ", callback) == "STOP" then
		return
	end

	if ConnectionService.Delays[name] then
		task.cancel(ConnectionService.Delays[name])
		ConnectionService.Delays[name] = nil
	end

	if waitTime and waitTime > 0 then
		ConnectionService.Delays[name] = task.delay(waitTime, function()
			ConnectionService.Delays[name] = nil
			callback()
		end)
	end
end

function ConnectionService.Cancel(name)
	if ConnectionService.Delays[name] then
		task.cancel(ConnectionService.Delays[name])
		ConnectionService.Delays[name] = nil
	end
end

local CFrameService = {}
local AllAxis = false

function CFrameService.GetPosition(obj)
	if typeof(obj) == "function" then obj = obj() end
	if Warning(" ", obj) == "STOP" then return end
	return typeof(obj) == "Vector3" and obj or obj.Position
end

function CFrameService.GetCFrame(obj)
	if Warning(" ", obj) == "STOP" then return end
	if typeof(obj) == "function" then obj = obj() end
	if typeof(obj) == "CFrame" then return obj end
	if typeof(obj) == "Vector3" then return CFrame.new(obj) end
	return obj.CFrame
end

function CFrameService.GetDistance(a, b)
	if Warning(" ", a) == "STOP" or Warning(" ", b) == "STOP" then return end
	local dis = (CFrameService.GetPosition(a) - CFrameService.GetPosition(b)).Magnitude
	return math.round(dis)
end

function CFrameService:Lerp(a, b, alpha)
	return CFrameService.GetCFrame(a):Lerp(CFrameService.GetCFrame(b), alpha)
end

function CFrameService.GetDirection(at, goal)
	at   = CFrameService.GetPosition(at)
	goal = CFrameService.GetPosition(goal)
	return (goal - at).Unit
end

function CFrameService.LookAt(part, goal)
	if Warning(" ", part) == "STOP" or Warning(" ", goal) == "STOP" then return end
	goal = CFrameService.GetPosition(goal)

	if AllAxis then
		part.CFrame = CFrame.new(part.Position, goal)
	else
		local dir = CFrameService.GetDirection(part, goal)
		dir = Vector3.new(dir.X, 0, dir.Z).Unit
		part.CFrame = CFrame.new(part.Position)
			* CFrame.Angles(0, math.atan2(-dir.X, -dir.Z), 0)
	end
end

function CFrameService.IsBehind(part,position)
	if Warning(" ", part) == "STOP" or Warning(" ", position) == "STOP" then return end
	local direction = CFrameService.GetDirection(part,position)
	local dot = CFrameService.GetCFrame(part).LookVector:Dot(direction)
	return dot <= 0
end

function CFrameService.Tween(part, goal, duration,lookat)
	if Warning(" ", part) == "STOP"
		or Warning(" ", goal) == "STOP"
		or Warning(" ", duration) == "STOP" then return end

	local elapsed = 0
	part.Anchored = true

	goal = CFrameService.GetCFrame(goal)

	local hum

	local me = part:FindFirstAncestorOfClass("Model")
	if me and me:FindFirstChildOfClass("Humanoid") then
		hum = me:FindFirstChildOfClass("Humanoid")
		hum.WalkSpeed = 0
		hum.JumpPower = 0
	end

	ConnectionService:NewConnection("TweenPosition", RunService.Heartbeat, "Connect", "Player", function(dt)
		if elapsed >= duration then
			ConnectionService.Disconnect("Player", "TweenPosition")
			part.Anchored = false
			if hum then
				hum.WalkSpeed = 16
				hum.JumpPower = 45
			end
			part.CFrame = goal
			return
		end
		elapsed += dt
		part.CFrame = CFrameService:Lerp(part, goal, GetAlpha(elapsed, duration))
		if lookat then
			CFrameService.LookAt(part,lookat) 
		end  
	end)
end

local function GetMe()
	if not Plr.Character then
		Plr.CharacterAdded:Wait()
	end
	local char = Plr.Character
	local hrp  = char:WaitForChild("HumanoidRootPart")
	local hum  = char:WaitForChild("Humanoid")
	return char, hum, hrp
end

local function GetInstances(target)
	if not target or typeof(target) == "string" then return nil, nil, nil, nil end
	local hum  = target:FindFirstChildOfClass("Humanoid")
	local root = target:FindFirstChild("HumanoidRootPart")
	local plr  = Players:GetPlayerFromCharacter(target)
	return target, hum, root, plr
end

local function NearestPlayer(useMouse)
	local char, _, hrp = GetMe()
	local pos = useMouse and Mouse.Hit.Position or CFrameService.GetPosition(hrp)

	local nearest, nearestDist = nil, math.huge
	for _, entity in ipairs(Live:GetChildren()) do
		if entity == char then continue end
		local root = entity:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		local d = CFrameService.GetDistance(pos, root)
		if d < nearestDist then
			nearest     = entity
			nearestDist = d
		end
	end
	return nearest
end

local SoundService = {}

function SoundService.PlaySound(sound)
	sound = typeof(sound) == "string" and SoundComponents:FindFirstChild(sound) or sound
	if Warning(" ", sound) == "STOP" then return end

	sound = sound:Clone()
	sound.Parent = Camera
	sound:Play()
	Debris:AddItem(sound, sound.TimeLength)
end

local HighlightService = {}

function HighlightService.FadeIn(highlight, name)
	highlight.FillTransparency    = 1
	highlight.OutlineTransparency = 1
	TweenService:Create(highlight, TweenInfos.Highlight, {
		FillTransparency    = Templates.VFX[name].FillTransparency,
		OutlineTransparency = Templates.VFX[name].OutlineTransparency,
	}):Play()
end

function HighlightService.FadeOut(highlight)
	TweenService:Create(highlight, TweenInfos.Highlight, {
		FillTransparency = 1, OutlineTransparency = 1,
	}):Play()
	ConnectionService:Delay("Highlight-FadeOut", TweenInfos.Highlight.Time, function()
		highlight:Destroy()
	end)
end

function HighlightService:Highlight(name, duration)
	local template = Templates.VFX[name]
	if not template then Warning("Highlight template not found: " .. tostring(name)) return end

	local h = template:Clone()
	h.Enabled = true
	HighlightService.FadeIn(h, name)

	if duration then
		ConnectionService:Delay("Highlight-Fadein", duration, function()
			HighlightService.FadeOut(h)
		end)
	end

	return h
end

local function CountDown(duration, rate, onTick, onEnd, name)
	if Warning(" ", duration) == "STOP" then return end

	local t       = duration
	local elapsed = 0
	onTick(t)

	ConnectionService:NewConnection(name, RunService.RenderStepped, "Connect", "Player", function(dt)
		elapsed += dt
		if elapsed >= rate then
			elapsed = 0
			t -= rate
			if t <= 0 then
				t = 0
				onTick(t)
				if onEnd then onEnd() end
				ConnectionService.Disconnect("Player", name)
			else
				onTick(t)
			end
		end
	end)
end

local Kills      = TargetInfo:FindFirstChild("Kills")
local Streak     = TargetInfo:FindFirstChild("Streak")
local TotalKills = TargetInfo:FindFirstChild("Total Kills")
local Ping       = TargetInfo:FindFirstChild("Ping")

