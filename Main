UserInputService:GetPropertyChangedSignal("MouseBehavior"):Connect(function()
	if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then
		PauseStare()
	else
		RestoreStare()
	end
end)

local function PressKey(Key, Duration)
	if Warning(nil, Key) == "STOP" then return end
	Key = KeyCode(Key)
	VirtualInputManager:SendKeyEvent(true, Key, false, game)
	ConnectionService:Delay("KeyRelease" .. Key.Name, Duration, function()
		VirtualInputManager:SendKeyEvent(false, Key, false, game)
	end)
end

local HadRagdoll = false

local function Jump()
	local _, Humanoid = GetMe()
	Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
end

local UltimateGui = PlrGui:WaitForChild("Bar")
UltimateGui.ResetOnSpawn = false

local MagicHealthBar = UltimateGui.MagicHealth.Health
TweenService:Create(MagicHealthBar.Glow, TweenInfos.UI, {ImageTransparency = 0.7}):Play()
TweenService:Create(MagicHealthBar:WaitForChild("Bar").Bar,TweenInfos.UI,{ImageColor3 = Color3.fromRGB(200, 0, 0)}):Play()

local function Connect()
	task.wait(1)
	local char, hum, hrp = GetMe()
	local animator = hum:WaitForChild("Animator")

	MagicHealthBar = PlrGui:WaitForChild("Bar").MagicHealth.Health

	char:SetAttribute("UltimateName", "GERP HUB")
	TweenService:Create(MagicHealthBar.Glow, TweenInfos.UI, {ImageTransparency = 0.7}):Play()
	TweenService:Create(MagicHealthBar:WaitForChild("Bar").Bar,TweenInfos.UI,{ImageColor3 = Color3.fromRGB(0, 0, 0)}):Play()

	for skill in pairs(CooldownValues) do
		CooldownsHolder[skill]:FindFirstChild("Title").Text = skill
	end
	
	ConnectionService:NewConnection("Died", hum.Died, "Once", "Player", function()
		ConnectionService.Disconnect("Player")
	end)

	ConnectionService:NewConnection("AncestryChanged", char.AncestryChanged, "Once", "Player", function()
		ConnectionService.Disconnect("Player")
	end)

	ConnectionService:NewConnection("AnimationPlayed", animator.AnimationPlayed, "Connect", "Player",
		function(track)
			local anim = track.Animation
			local target, _, targetRoot = GetInstances(NearestPlayer(false))

			if UppercutIDS[anim.AnimationId] then
				if char:GetAttribute("DragonUppercut") then return end
				if not targetRoot or CFrameService.GetDistance(hrp, targetRoot) > 8 then return end
				if IsShiftLocked() then return end
				if IsDashOnCD() then return end

				if Toggles["Auto Dripz"] then
					hum.WalkSpeed = 0
					hum.JumpPower = 0
					local buh = CFrameService.IsBehind(hrp, targetRoot)
						and CFrame.new(0, 0, 4)
						or  CFrame.new(0, 0, -4)
					hrp.CFrame = targetRoot.CFrame * buh
					CFrameService.LookAt(hrp,CFrame.new(0,0,-buh.Z))
					hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + Vector3.new(0, 53, 20)
				end

				ConnectionService:NewConnection("UppercutHit",
					track:GetMarkerReachedSignal("hitreg"), "Once", "Player", function()
						if Toggles["Auto Dripz"] then
							if IsShiftLocked() then return end
							if IsDashOnCD() then return end
							AllTechs["Auto Dripz"](
								targetRoot,
								CFrameService.IsBehind(hrp, targetRoot) and "Back" or "Front"
							)
							hum.WalkSpeed = 16
							hum.JumpPower = 45
						end
					end)

			elseif ForthIDS[anim.AnimationId] then
				if not targetRoot or CFrameService.GetDistance(hrp, targetRoot) > 8 then return end
				if IsShiftLocked() then return end
				if IsDashOnCD() then return end
				hum.WalkSpeed = 0
				hum.JumpPower = 0
				ConnectionService:NewConnection("ForthHit",
					track:GetMarkerReachedSignal("hitreg"), "Once", "Player", function()
						if Toggles["Auto Twisted"] then
							if IsDashOnCD() then return end
							AllTechs["Auto Twisted"](targetRoot)
							hum.WalkSpeed = 16
							hum.JumpPower = 45
						end
					end)

			elseif SideIDS[anim.AnimationId] and not workspace:GetAttribute("NoDashCooldown") then
				CDTrigger("Side Dash")
				if HadRagdoll then CDTrigger("Evasive") end

			elseif FrontIDS[anim.AnimationId] and not workspace:GetAttribute("NoDashCooldown") then
				FrontDashTick = tick()
				CDTrigger("Front Dash")
				if HadRagdoll then CDTrigger("Evasive") end
			end
		end)

	ConnectionService:NewConnection("Ragdolled", char.ChildAdded, "Connect", "Player", function(child)
		if child.Name == "Ragdoll" or child.Name == "BeingLaunched" then PauseStare() end
	end)

	ConnectionService:NewConnection("Unragdolled", char.ChildRemoved, "Connect", "Player", function(child)
		if child.Name == "Ragdoll" or child.Name == "BeingLaunched" then
			HadRagdoll = true
			ConnectionService:Delay("Has Ragdoll", 0.2, function()
				HadRagdoll = false
			end)
			RestoreStare()
		end
	end)

	ConnectionService:NewConnection("UltName", char:GetAttributeChangedSignal("UltimateName"), "Connect", "Player", function()
		if char:GetAttribute("UltimateName") == "GERP HUB" then return end
		char:SetAttribute("UltimateName", "GERP HUB")
	end)
end

Connect()
Plr.CharacterAdded:Connect(Connect)

--[[
    Live Service
]]--

local LiveService = {}

LiveService.Info = function(guy)
	local guy, hum, hrp, player = GetInstances(guy)
	if not player then return end

	local board = Templates.Board.Info:Clone()
	board.Parent = guy:FindFirstChild("Head")

	local image = MovesetIcon[GetMoveset(guy)]
	if image then
		board.Moveset.Image = image
	end

	local InformationFrame = board.Info
	local CurrentStreak    = player:GetAttribute("CurrentStreak") or guy:GetAttribute("CurrentStreak") or 0

	if CurrentStreak < 0 then
		InformationFrame.Streak.Visible = false
	else
		ChangeText(InformationFrame.Streak, CurrentStreak)
	end

	ChangeText(InformationFrame.Kills,            player:GetAttribute("Kills"))
	ChangeText(InformationFrame["Total Kills"],   player:GetAttribute("TotalKillsFrb"))

	ConnectionService:NewConnection("Kills", player:GetAttributeChangedSignal("Kills"), "Connect", "Live", function()
		ChangeText(InformationFrame.Kills, player:GetAttribute("Kills"))
	end, guy.Name)

	ConnectionService:NewConnection("Total Kills", player:GetAttributeChangedSignal("TotalKillsFrb"), "Connect", "Live", function()
		ChangeText(InformationFrame["Total Kills"], player:GetAttribute("TotalKillsFrb"))
	end, guy.Name)

	local streakSignal = player:GetAttribute("CurrentStreak") ~= nil
		and player:GetAttributeChangedSignal("CurrentStreak")
		or  guy:GetAttributeChangedSignal("CurrentStreak")

	ConnectionService:NewConnection("Streak", streakSignal, "Connect", "Live", function()
		CurrentStreak = player:GetAttribute("CurrentStreak") or guy:GetAttribute("CurrentStreak") or 0
		if CurrentStreak < 0 then
			InformationFrame.Streak.Visible = false
		else
			ChangeText(InformationFrame.Streak, CurrentStreak)
		end
	end, guy.Name)
end

local CounterDuration = 1
local DeathCounterDuration = 10

local function UpdateLiveValues(bar, alpha)
	local fill = bar:FindFirstChild("Fill")
	TweenService:Create(fill, TweenInfos.BarTween, {Size = UDim2.fromScale(1, alpha)}):Play()
end

local function UpdateLiveEvasive(bar)
	bar.Fill.Size = UDim2.fromScale(1, 1)
	TweenService:Create(bar.Fill,
		TweenInfo.new(CooldownValues.Evasive, Enum.EasingStyle.Linear),
		{Size = UDim2.fromScale(1, 0)}):Play()
end

LiveService.Values = function(guy)
	local guy, hum, hrp, player = GetInstances(guy)

	local board = Templates.Board.ValuesHolder:Clone()
	board.Parent = hrp

	UpdateLiveValues(board.Health, GetAlpha(hum.Health, hum.MaxHealth))

	ConnectionService:NewConnection("HealthUpdate", hum.HealthChanged, "Connect", "Live", function()
		if hum.Health <= 0 then
			ConnectionService.Disconnect("Live", nil, guy.Name)
			return
		end
		UpdateLiveValues(board.Health, GetAlpha(hum.Health, hum.MaxHealth))
	end, guy.Name)

	if player then
		UpdateLiveValues(board.Ultimate, GetAlpha(player:GetAttribute("Ultimate"), 100))
		ConnectionService:NewConnection("UltimateUpdate", player:GetAttributeChangedSignal("Ultimate"), "Connect", "Live", function()
			UpdateLiveValues(board.Ultimate, GetAlpha(player:GetAttribute("Ultimate"), 100))
		end, guy.Name)
	else
		UpdateLiveValues(board.Ultimate, 0)
	end
end

local StopM1 = false

local function OnCounter(guy)
	local char, hum, hrp = GetMe()
	local guy, hisHum, hisHrp, player = GetInstances(guy)

	if CFrameService.GetDistance(hrp, hisHrp) < 8 then
		SoundService.PlaySound("Counter")
		SilentAimService.DisableTemporarly(CounterDuration)
		local goal = CFrameService.IsBehind(hrp, hisHrp)
			and CFrame.new(0, 0, 9)
			or  CFrame.new(0, 0, -9)
		StopM1 = true
		CFrameService.Tween(hrp, hisHrp.CFrame * goal, 0.4,hisHrp.CFrame * goal)
	else
		StopM1 = false
	end

	ConnectionService:NewConnection(guy.Name.."-AntiCounter",RunService.RenderStepped,"Connect","Player",function()
		if CFrameService.GetDistance(hrp, hisHrp) < 8 then
			StopM1 = true
		else
			StopM1 = false
		end
	end)
		
	local sh = guy:FindFirstChild("Stare")

	if sh then 
		sh.Enabled = false
		sh.Parent = ReplicatedStorage 
	end

	local Highlight = HighlightService:Highlight("Counter", CounterDuration)
	Highlight.Parent = hisHrp
	
	local counterFrame = hisHrp:FindFirstChild("Counters").Counter
	counterFrame.Visible = true
	
	ConnectionService:Delay(guy.Name .. "-Counter", CounterDuration, function()
		counterFrame.Visible = false
		ConnectionService.Disconnect("Player", guy.Name.."-AntiCounter")
		if sh then 
			sh.Parent = guy 
			sh.Enabled = true 
		end
	end)
end

local function OnDeathCounter(guy)
	local char, hum, hrp = GetMe()
	local guy, hisHum, hisHrp, player = GetInstances(guy)
	
	SoundService.PlaySound("Bell")
	
	if CFrameService.GetDistance(hrp, hisHrp) < 8 then
		SilentAimService.DisableTemporarly(CounterDuration)
		local goal = CFrameService.IsBehind(hrp, hisHrp)
			and CFrame.new(0, 0, 9)
			or  CFrame.new(0, 0, -9)
		StopM1 = true
		CFrameService.Tween(hrp, hisHrp.CFrame * goal, 0.4,function() return hisHrp.CFrame * goal end)
	else
		StopM1 = false
	end
	
	ConnectionService:NewConnection(guy.Name.."-AntiDeathCounter",RunService.RenderStepped,"Connect","Player",function()
		if CFrameService.GetDistance(hrp, hisHrp) < 8 then
			StopM1 = true
		else
			StopM1 = false
		end
	end)
	
	local sh = guy:FindFirstChild("Stare")

	if sh then 
		sh.Enabled = false
		sh.Parent = ReplicatedStorage 
	end

	local Highlight = HighlightService:Highlight("Death", DeathCounterDuration)
	Highlight.Parent = hisHrp
	
	local counterFrame = hisHrp:FindFirstChild("Counters")["Death Counter"]
	counterFrame.Visible = true
	
	ConnectionService:Delay(guy.Name .. "-DeathCounter", DeathCounterDuration, function()
		counterFrame.Visible = false
		ConnectionService.Disconnect("Player", guy.Name.."-AntiDeathCounter")
		if sh then sh.Parent = guy sh.Enabled = true end
	end)
end

LiveService.Counter = function(guy)
	local _, _, hrp = GetInstances(guy)
	local board = Templates.Board.Counters:Clone()
	board.Parent = hrp
end

LiveService.Handle = function(guy)
	task.wait(1)
	if guy == GetMe() then return end

	local hum      = guy:WaitForChild("Humanoid")
	local hrp      = guy:WaitForChild("HumanoidRootPart")
	local animator = hum:FindFirstChildOfClass("Animator")

	ConnectionService.LiveConnections[guy.Name] = {}

	ConnectionService:NewConnection("ragdolled", guy.ChildAdded, "Connect", "Live", function(child)
		if child.Name == "Ragdoll" or child.Name == "BeingLaunched" then
			ConnectionService.Cancel(guy.Name .. "-Unragdoll")
			guy:SetAttribute("HadRagdoll", true)
		end
	end, guy.Name)

	ConnectionService:NewConnection("unragdolled", guy.ChildRemoved, "Connect", "Live", function(child)
		if child.Name == "Ragdoll" or child.Name == "BeingLaunched" then
			ConnectionService:Delay(guy.Name .. "-Unragdoll", 0.2, function()
				guy:SetAttribute("HadRagdoll", false)
			end)
		end
	end, guy.Name)

	ConnectionService:NewConnection("animPlayed", animator.AnimationPlayed, "Connect", "Live", function(track : AnimationTrack)
		local id = track.Animation.AnimationId
		if SideIDS[id] or FrontIDS[id] then
			if guy:GetAttribute("HadRagdoll") then
				guy:SetAttribute("EvasiveCD", true)
				UpdateLiveEvasive(hrp:FindFirstChild("Values"):FindFirstChild("Evasive"))
				guy:SetAttribute("Evasive", CooldownValues["Evasive"])
				CountDown(CooldownValues["Evasive"], 1, function(t)
					guy:SetAttribute("Evasive", t)
				end, function()
					guy:SetAttribute("Evasive", 0)
					guy:SetAttribute("EvasiveCD", false)
				end, guy.Name .. "-Evasive", "Live", guy.Name)
			end
		elseif CounterIDS[id] then
			OnCounter(guy)
		elseif SaitamaIDS[id] then
			guy:SetAttribute("UsedDeath",true)
			ConnectionService:Delay(guy.Name.."-UsedDeath",track.Length,function()
				guy:SetAttribute("UsedDeath",false)
			end)
		end
	end, guy.Name)

	if hum then
		ConnectionService:NewConnection("Died", hum.Died, "Once", "Live", function()
			ConnectionService.Disconnect("Live", nil, guy.Name)
		end, guy.Name)
	end

	ConnectionService:NewConnection("Bye Daddy", guy.AncestryChanged, "Once", "Live", function()
		ConnectionService.Disconnect("Live", nil, guy.Name)
	end, guy.Name)

	local player = Players:GetPlayerFromCharacter(guy)
	if player then
		ConnectionService:NewConnection("PlayerLeft", OnLeaving.Event, "Connect", "Live", function(PlayerLeft)
			if player == PlayerLeft then
				ConnectionService.Disconnect("Live", nil, guy.Name)
			end
		end, guy.Name)
		ConnectionService:NewConnection("Ulted",guy:GetAttributeChangedSignal("Ulted"),"Connect","Live",function()
			if guy:GetAttribute("Ulted") and GetMoveset(guy) == "Bald" then
				SoundService.PlaySound("Ulted")
				local highlight = HighlightService:Highlight("Ulted")
				highlight.Parent = guy
				local sh = guy:FindFirstChild("Stare")
				if sh then 
					sh.Enabled = false
					sh.Parent = ReplicatedStorage 
				end
				ConnectionService.Yield(function() return not guy:GetAttribute("Ulted") end,120)
				task.wait(0.5)
				if not guy:GetAttribute("UsedDeath") then
					Warning(guy.Name.." Used Death Counter")
					OnDeathCounter(guy)
				end
			end
		end,guy.Name)
	end

	LiveService.Info(guy)
	LiveService.Values(guy)
	LiveService.Counter(guy)
end

for _, guy in Live:GetChildren() do
	task.spawn(LiveService.Handle,guy)
end

Live.ChildAdded:Connect(function(guy)
	guy:WaitForChild("HumanoidRootPart")
	guy:WaitForChild("Humanoid")

	task.wait(0.5)
	if guy.Name == SilentAimService.TargetName and SilentAimService.HadTarget then
		SilentAimService.Target     = guy
		SilentAimService.TargetName = nil
		SilentAimService.HadTarget  = false

		if Toggles["Silent Aim"] then
			local h = HighlightService:Highlight("Stare")
			if h then h.Parent = guy end
			SilentAimService.Highlight = h
		end

		TargetInformation(true)

		if Toggles["Silent Aim"] then
			EnableStare()
		end
	end
	LiveService.Handle(guy)
end)

--[[
    Startup
]]--

TogglesHolder.Position  = UDim2.new(1.2, -10, 0.5,  0)
TargetInfo.Position     = UDim2.new(-0.3, 10,  0.55, 0)
CooldownsHolder.Position = UDim2.new(0.5, 0,  -0.1, 0)

UI.Credit.TextTransparency = 1
UI.Enabled = true

TweenService:Create(TogglesHolder,   TweenInfos.UI, {Position = UDim2.new(1,   0, 0.5,  0)}):Play()
TweenService:Create(CooldownsHolder, TweenInfos.UI, {Position = UDim2.new(0.5, 0, 0.1,  0)}):Play()
TweenService:Create(UI.Credit,       TweenInfos.UI, {TextTransparency = 0.5}):Play()

UI.Credit.AncestryChanged:Once(function()
	Plr:Kick("Dont Do That, Next Time It'll Be A Ban :3")
end)

UI.Credit.Destroying:Once(function()
	Plr:Kick("Dont Do That, Next Time It'll Be A Ban :3")
end)

print("[GERP HUB]: Loaded successfully.")

--[[
	Remote Manipulation
]]--

setreadonly(getrawmetatable(game), false)

local old

old = hookmetamethod(game, "__namecall", function(self,...)
	local method = getnamecallmethod()

	local args = {...}

	if self.Name == "Communicate" and method == "FireServer" then
		if args["Goal"] == "LeftClick" and StopM1 then return end -- stop m1s
	end
	
	return old(self, ...)
end)
