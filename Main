    Mobile button
]]--

if IsMobile then
	local mobileBtn = Templates.Screen.MobileButton:Clone()
	mobileBtn.Parent = TogglesHolder

	local baseSize = mobileBtn.Size
	local sx, sy   = baseSize.X, baseSize.Y

	mobileBtn.MouseButton1Click:Connect(function()
		TechCallbacks.Enabled["Lock Target"]()
		SoundService.PlaySound("Mobile")
		TweenService:Create(mobileBtn, TweenInfos.TechClicked,
			{Size = UDim2.new(sx.Scale, sx.Offset, sy.Scale * 1.1, sy.Offset)}):Play()
		task.wait(TweenInfos.TechClicked.Time)
		TweenService:Create(mobileBtn, TweenInfos.TechClicked, {Size = baseSize}):Play()
	end)
end

--[[
    Cooldown UI
]]--

local function Cooldown(name)
	if Warning(nil, name) == "STOP" then return end
	local cd = Templates.Screen.Cooldown
	if not cd then return end
	cd = cd:Clone()
	cd.Parent = CooldownsHolder
	cd:FindFirstChild("Title").Text = name
	cd.Name = name
end

for skill in pairs(CooldownValues) do
	Cooldown(skill)
end

local function CDTrigger(name, extra)
	local cd = typeof(name) == "string" and CooldownsHolder:FindFirstChild(name) or name
	if not cd then return end

	name = typeof(name) == "string" and name or name.Name

	local duration = CooldownValues[name]
	cd:FindFirstChild("Fill").Size = UDim2.fromScale(1, 1)

	TweenService:Create(cd:FindFirstChild("Fill"),
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{Size = UDim2.fromScale(0, 1)}):Play()

	CountDown(duration, 1, function(t)
		cd:FindFirstChildOfClass("TextLabel").Text = t > 0 and (name .. ": " .. t .. "s") or name
	end, function()
		cd:FindFirstChildOfClass("TextLabel").Text = name
	end, extra or name)
end

local function TechFx(name)
	if Warning(nil, name) == "STOP" then return end
	local char = GetMe()
	local head = char:FindFirstChild("Head")
	if not head then return end

	local gui = Templates.VFX.Tech
	if not gui then return end
	gui = gui:Clone()
	gui.Parent = head
	gui.Size   = UDim2.fromScale(0, 0)

	local label = gui:FindFirstChildOfClass("TextLabel")
	if label then label.Text = name:upper() end

	TweenService:Create(gui, TweenInfos.TechFx, {Size = Templates.VFX.Tech.Size}):Play()
	task.delay(TweenInfos.TechFx.Time + 1.5, function()
		TweenService:Create(gui, TweenInfos.TechFxOut, {Size = UDim2.fromScale(0, 0)}):Play()
		task.delay(TweenInfos.TechFxOut.Time, function()
			gui:Destroy()
		end)
	end)
end

local FrontDashTick = 0

local function IsDashOnCD()
	if workspace:GetAttribute("NoDashCooldown") then return false end
	return (tick() - FrontDashTick) < CooldownValues["Front Dash"]
end

local function IsShiftLocked()
	return UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
end

local function FrontDash()
	local char = GetMe()
	local comm = char and char:FindFirstChild("Communicate")
	if comm then
		comm:FireServer({Dash = Enum.KeyCode.W, Key = Enum.KeyCode.Q, Goal = "KeyPress"})
	end
end

local AllTechs = {
	["Auto Twisted"] = function(targetRoot)
		local _, hum, root = GetMe()
		if not root or not targetRoot then
			Warning("One of the roots doesn't exist for Auto Twisted")
			return
		end

		TechFx("TWISTED TECH")
		hum.AutoRotate = false
		SilentAimService.DisableTemporarly(0.7)

		FrontDash()

		local cf = CFrameService.GetCFrame(root)
		CFrameService.LookAt(root, cf * CFrame.new(6,   0,  3)) task.wait(0.1)
		CFrameService.LookAt(root, cf * CFrame.new(8,   0, -6)) task.wait(0.1)
		CFrameService.LookAt(root, cf * CFrame.new(0,   0,-12)) task.wait(0.3)
		CFrameService.LookAt(root, targetRoot)                   task.wait(0.2)

		SilentAimService.EnableTemporarly(0.4, targetRoot)
		hum.AutoRotate = true
	end,

	["Auto Dripz"] = function(targetRoot, origin)
		local char, hum, hrp = GetMe()
		if not hrp or not targetRoot then
			Warning("One of the roots doesn't exist for Auto Dripz")
			return
		end

		TechFx("DRIPZ TECH")
		hum.AutoRotate = false
		SilentAimService.DisableTemporarly(2)

		local Offset = origin == "Front" and CFrame.new(0, 0, 11) or CFrame.new(0, 0, -11)

		FrontDash()

		for _, l in char:GetChildren() do
			if l:IsA("Part") then
				l.CanCollide = false
			end
		end

		hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + Vector3.new(0, 53, 0)

		task.wait(0.15)

		CFrameService.LookAt(hrp, targetRoot.CFrame * Offset)

		ConnectionService.Yield(function()
			return not targetRoot.Parent
				or CFrameService.GetDistance(hrp, targetRoot) >= math.abs(Offset.Z)
		end, 5)

		if not targetRoot.Parent then hum.AutoRotate = true return end

		SilentAimService.EnableTemporarly(0.5, targetRoot)

		ConnectionService.Yield(function()
			return not targetRoot.Parent
				or CFrameService.GetDistance(hrp, targetRoot) <= 4
		end, 5)

		if not targetRoot.Parent then hum.AutoRotate = true return end

		SilentAimService.DisableTemporarly(1)
		CFrameService.LookAt(hrp, targetRoot.CFrame)

		task.delay(0.1,function()
			hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + Vector3.new(0, 50, 0)
		end)

		ConnectionService.Yield(function()
			return not targetRoot.Parent
				or CFrameService.GetDistance(hrp, targetRoot) >= 6
		end, 5)
		if not targetRoot.Parent then hum.AutoRotate = true return end

		SilentAimService.EnableTemporarly(0.5, targetRoot)
		task.wait(0.15)

		hum.AutoRotate = true
	end,
}

