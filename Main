local function Warning(text, object)
	if object == nil and text == nil then
		warn("[GERP HUB]: A provided argument doesn't exist! Stopping execution.")
		return "STOP"
	elseif text ~= nil then
		warn("[GERP HUB]: " .. tostring(text))
	end
end

