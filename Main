local function Warning(text, object)
    if object == nil and text == " " then
        warn("[GERP HUB]: A provided argument doesn't exist! Stopping execution.")
        return "STOP"
    elseif text ~= " " then
        warn("[GERP HUB]: " .. text)
    end
end

if getgenv().GerpHubLoaded then
    Warning("Gerp Hub is already loaded!")
    return
end
getgenv().GerpHubLoaded = true

